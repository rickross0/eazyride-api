# ── Database ──────────────────────────────────────────────────
# Render will auto-populate DATABASE_URL from the linked Postgres service
# Format: postgresql://user:password@host:5432/eazyride_haye?sslmode=require
DATABASE_URL=postgresql://neondb_owner:npg_S8tgRfT5QXuz@ep-orange-tree-aluirbqr-pooler.c-3.eu-central-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# ── Redis (optional — caching disabled if not set) ────────────
# Use a managed Redis (Upstash, Render Redis, etc.) or leave blank
REDIS_URL=

# ── JWT ──────────────────────────────────────────────────────
JWT_SECRET=REPLACE_WITH_STRONG_SECRET
JWT_EXPIRES=7d

# ── Server ───────────────────────────────────────────────────
PORT=3000
NODE_ENV=production
CORS_ORIGIN=https://your-frontend-url.com,https://your-app-url.com

# ── WaafiPay (Production) ────────────────────────────────────
WAAFI_ENV=production
WAAFI_MERCHANT_UID=YOUR_MERCHANT_UID
WAAFI_API_USER_ID=YOUR_API_USER_ID
WAAFI_API_KEY=YOUR_API_KEY
WAAFI_WEBHOOK_SECRET=YOUR_WEBHOOK_SECRET

# ── Firebase / FCM ───────────────────────────────────────────
GOOGLE_APPLICATION_CREDENTIALS=./serviceAccountKey.json
