# ── Database ──────────────────────────────────────────────────
# Render will auto-populate DATABASE_URL from the linked Postgres service
# Format: postgresql://user:password@host:5432/eazyride_haye?sslmode=require
DATABASE_URL=

# ── Redis (optional — caching disabled if not set) ────────────
# Use a managed Redis (Upstash, Render Redis, etc.) or leave blank
REDIS_URL=

# ── JWT ──────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('base64url'))"
JWT_SECRET=
JWT_EXPIRES=7d

# ── Server ────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# CORS — comma-separated list of allowed origins (no spaces)
# Add your landing site URL and any other frontends
CORS_ORIGIN=https://eazyride-site.onrender.com,https://rickross0.github.io

# Base URL for generating image URLs (your Render service URL)
BASE_URL=https://eazyride-haye-api.onrender.com

# ── WaafiPay ─────────────────────────────────────────────────
# Use "sandbox" for testing, "production" when going live
WAAFI_ENV=sandbox
WAAFI_MERCHANT_UID=
WAAFI_API_USER_ID=
WAAFI_API_KEY=
WAAFI_WEBHOOK_SECRET=

# ── Firebase / FCM ───────────────────────────────────────────
# Path to service account key (or use GOOGLE_APPLICATION_CREDENTIALS env var)
GOOGLE_APPLICATION_CREDENTIALS=./serviceAccountKey.json
