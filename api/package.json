{
  "name": "eazyride-haye-backend",
  "version": "3.0.0",
  "description": "EazyRide + Haye! Premium Super-App Backend",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "db:migrate": "prisma migrate dev",
    "db:seed": "node prisma/seed.js",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "build": "npm run db:generate",
    "render-start": "node src/db/ensureSchema.js; npx prisma db push; node prisma/seed.js; node src/server.js",
    "postinstall": "npx prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^6.2.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "firebase-admin": "^12.0.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "node-fetch": "^2.7.0",
    "pdfkit": "^0.14.0",
    "socket.io": "^4.7.4",
    "uuid": "^9.0.0",
    "winston": "^3.11.0",
    "xss-clean": "^0.1.4",
    "hpp": "^0.2.3",
    "crypto-js": "^4.2.0",
    "express-validator": "^7.2.0",
    "axios": "^1.6.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.3",
    "prisma": "^6.2.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}